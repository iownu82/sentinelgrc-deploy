# SentinelGRC — npm security configuration
# Hardens npm install against supply chain attacks

# Ignore postinstall/preinstall/install scripts in ALL packages
# This is the exact vector used in the Axios March 2026 attack
ignore-scripts=true

# Require exact versions from lockfile (use npm ci, not npm install)
# If lockfile is missing or doesn't match, fail loudly
save-exact=true

# Audit level — fail build if any HIGH or CRITICAL vulnerabilities found
audit-level=high

# Use npm's built-in integrity checking (sha512 verification)
# This catches tampered packages even if they're on the registry
package-lock=true

# Disable package execution via npx without explicit confirmation
# Prevents accidental execution of malicious packages
yes=false
