# SentinelGRC — Environment Variables
# Copy this file to .env and fill in your Supabase credentials
# Never commit .env to git (it's in .gitignore)

# ── Supabase (required for cloud persistence) ─────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Optional: future GovCloud integration ────────────────────────────────
# VITE_AWS_REGION=us-gov-west-1
# VITE_AWS_BUCKET=sentinelgrc-evidence
